# ─── LexGuard Backend Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Server Config ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ── Environment (development | production) ────────────────────────────────────
ENVIRONMENT=development

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── CORS Allowed Origins (comma-separated) ────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# ── CSP connect-src Additional Origins (comma-separated) ─────────────────────
# Add your production Cloud Run URL here, e.g.:
# CSP_CONNECT_ORIGINS=https://your-app.a.run.app
CSP_CONNECT_ORIGINS=

# ── Claude / Anthropic Model Config ───────────────────────────────────────────
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS_ANALYSIS=2500
CLAUDE_MAX_TOKENS_CHAT=1500
CLAUDE_MAX_TOKENS_PROMPT_EVAL=1500
CLAUDE_TEMP_ANALYSIS=0.2
CLAUDE_TEMP_CHAT=0.5
CLAUDE_TEMP_PROMPT_EVAL=0.1

# ── Upload / Input Limits ─────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_TEXT_INPUT_CHARS=500000
MAX_DOCUMENT_CONTEXT_CHARS=10000
MAX_PROMPT_CHARS=10000
MAX_PROMPT_CONTEXT_CHARS=5000
MAX_CHAT_MESSAGE_CHARS=10000
MAX_CHAT_DOC_CONTEXT_CHARS=50000
MAX_CLAUDE_DOC_CHARS=15000
